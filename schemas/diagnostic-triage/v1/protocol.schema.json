{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anionix.dev/schemas/diagnostic-triage/v1/protocol.schema.json",
  "title": "Diagnostic Triage JSON Lines Protocol V1",
  "oneOf": [
    { "$ref": "#/$defs/manifestEnvelope" },
    { "$ref": "#/$defs/requestEnvelope" },
    { "$ref": "#/$defs/observationEnvelope" },
    { "$ref": "#/$defs/evidenceEnvelope" },
    { "$ref": "#/$defs/fixCandidateEnvelope" },
    { "$ref": "#/$defs/executionEnvelope" },
    { "$ref": "#/$defs/completionEnvelope" }
  ],
  "$defs": {
    "manifestEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "kind", "adapter"],
      "properties": {
        "protocol_version": { "const": "diagnostic-triage.protocol/v1" },
        "kind": { "const": "manifest" },
        "adapter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version", "kind", "capabilities", "languages"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[a-z][a-z0-9.-]{0,127}$"
            },
            "version": { "type": "string", "minLength": 1, "maxLength": 64 },
            "kind": { "enum": ["PROVIDER", "OBSERVER"] },
            "capabilities": {
              "type": "array",
              "minItems": 1,
              "maxItems": 64,
              "uniqueItems": true,
              "items": { "$ref": "common.schema.json#/$defs/capability" }
            },
            "languages": {
              "type": "array",
              "maxItems": 64,
              "uniqueItems": true,
              "items": { "$ref": "common.schema.json#/$defs/language" }
            }
          }
        }
      }
    },
    "requestEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version", "kind", "request_id", "operation", "workspace",
        "targets", "required_capabilities", "optional_capabilities", "limits"
      ],
      "properties": {
        "protocol_version": { "const": "diagnostic-triage.protocol/v1" },
        "kind": { "const": "request" },
        "request_id": { "$ref": "common.schema.json#/$defs/uuid" },
        "operation": { "enum": ["CHECK", "FIX", "VERIFY", "OBSERVE"] },
        "workspace": { "$ref": "common.schema.json#/$defs/relativePath" },
        "targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "uniqueItems": true,
          "items": { "$ref": "common.schema.json#/$defs/relativePath" }
        },
        "required_capabilities": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "common.schema.json#/$defs/capability" }
        },
        "optional_capabilities": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "common.schema.json#/$defs/capability" }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "timeout_ms", "max_stdout_bytes", "max_stderr_bytes",
            "max_evidence_bytes", "max_events"
          ],
          "properties": {
            "timeout_ms": { "type": "integer", "minimum": 1, "maximum": 600000 },
            "max_stdout_bytes": { "type": "integer", "minimum": 0, "maximum": 16777216 },
            "max_stderr_bytes": { "type": "integer", "minimum": 0, "maximum": 4194304 },
            "max_evidence_bytes": { "type": "integer", "minimum": 0, "maximum": 1048576 },
            "max_events": { "type": "integer", "minimum": 0, "maximum": 10000 }
          }
        }
      }
    },
    "observationEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "kind", "request_id", "sequence", "observation"],
      "properties": {
        "protocol_version": { "const": "diagnostic-triage.protocol/v1" },
        "kind": { "const": "observation" },
        "request_id": { "$ref": "common.schema.json#/$defs/uuid" },
        "sequence": { "$ref": "common.schema.json#/$defs/eventSequence" },
        "observation": { "$ref": "model.schema.json#/$defs/observation" }
      }
    },
    "evidenceEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "kind", "request_id", "sequence", "evidence"],
      "properties": {
        "protocol_version": { "const": "diagnostic-triage.protocol/v1" },
        "kind": { "const": "evidence" },
        "request_id": { "$ref": "common.schema.json#/$defs/uuid" },
        "sequence": { "$ref": "common.schema.json#/$defs/eventSequence" },
        "evidence": { "$ref": "model.schema.json#/$defs/evidence" }
      }
    },
    "fixCandidateEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "kind", "request_id", "sequence", "fix_candidate"],
      "properties": {
        "protocol_version": { "const": "diagnostic-triage.protocol/v1" },
        "kind": { "const": "fix_candidate" },
        "request_id": { "$ref": "common.schema.json#/$defs/uuid" },
        "sequence": { "$ref": "common.schema.json#/$defs/eventSequence" },
        "fix_candidate": { "$ref": "model.schema.json#/$defs/fixCandidate" }
      }
    },
    "executionEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "kind", "request_id", "sequence", "execution"],
      "properties": {
        "protocol_version": { "const": "diagnostic-triage.protocol/v1" },
        "kind": { "const": "execution" },
        "request_id": { "$ref": "common.schema.json#/$defs/uuid" },
        "sequence": { "$ref": "common.schema.json#/$defs/eventSequence" },
        "execution": { "$ref": "model.schema.json#/$defs/execution" }
      }
    },
    "completionEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version", "kind", "request_id", "sequence", "status",
        "tool_exit_code", "tool_duration_ms", "counts", "evidence_bytes"
      ],
      "properties": {
        "protocol_version": { "const": "diagnostic-triage.protocol/v1" },
        "kind": { "const": "completion" },
        "request_id": { "$ref": "common.schema.json#/$defs/uuid" },
        "sequence": { "$ref": "common.schema.json#/$defs/eventSequence" },
        "status": { "enum": ["COMPLETE", "INCOMPLETE", "UNSUPPORTED"] },
        "tool_exit_code": { "type": ["integer", "null"], "minimum": 0, "maximum": 255 },
        "tool_duration_ms": { "$ref": "common.schema.json#/$defs/durationMs" },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["observations", "evidence", "fix_candidates", "executions"],
          "properties": {
            "observations": { "type": "integer", "minimum": 0, "maximum": 10000 },
            "evidence": { "type": "integer", "minimum": 0, "maximum": 10000 },
            "fix_candidates": { "type": "integer", "minimum": 0, "maximum": 10000 },
            "executions": { "type": "integer", "minimum": 0, "maximum": 10000 }
          }
        },
        "evidence_bytes": { "type": "integer", "minimum": 0, "maximum": 10485760000 },
        "message": { "type": "string", "minLength": 1, "maxLength": 8192 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "COMPLETE" } },
            "required": ["status"]
          },
          "then": { "properties": { "tool_exit_code": { "type": "integer" } } },
          "else": {
            "required": ["message"],
            "properties": { "tool_exit_code": { "type": "null" } }
          }
        }
      ]
    }
  }
}
