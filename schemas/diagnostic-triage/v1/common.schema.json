{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anionix.dev/schemas/diagnostic-triage/v1/common.schema.json",
  "title": "Diagnostic Triage Common Types V1",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "sourceRevision": {
      "type": "string",
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?:\\.|(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$))(?!.*//)(?!.*\/$)[^\\\\\\u0000]+)$"
    },
    "language": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9+.#-]{0,63}$"
    },
    "severity": {
      "enum": ["ERROR", "WARNING", "INFO"]
    },
    "origin": {
      "enum": ["NORMAL", "BOUNDARY", "MALFORMED", "FUZZ", "GENERATED", "UNKNOWN"]
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line", "column"],
      "properties": {
        "line": {
          "description": "One-based line number.",
          "type": "integer",
          "minimum": 1,
          "maximum": 4294967295
        },
        "column": {
          "description": "One-based Unicode code-point column.",
          "type": "integer",
          "minimum": 1,
          "maximum": 4294967295
        }
      }
    },
    "location": {
      "description": "One-based half-open [start, end) source range. An omitted end is a point at start; an explicit end equal to start is a valid zero-width insertion point. Columns count Unicode code points.",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "start"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "start": { "$ref": "#/$defs/position" },
        "end": {
          "description": "Exclusive end position; omission denotes a point at start.",
          "$ref": "#/$defs/position"
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 64 },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "rule_id": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0,
      "maximum": 600000
    },
    "eventSequence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "capability": {
      "type": "string",
      "minLength": 4,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9.-]*/v[1-9][0-9]*$"
    }
  }
}
