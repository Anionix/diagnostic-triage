/- LLM contract: DISCOVERED -> NORMALIZED -> CLASSIFIED -> FIX_PROPOSED -> VERIFIED -> REPORTED; execution terminal: INCOMPLETE | UNSUPPORTED. Pure Bool gate; Rust tests scanning, bounds, complexity. -/ def acceptsSingleBackslashRoot (firstChars secondChars : Nat) (firstTyped secondTyped knownRoot escapeLike hasThirdSeparator : Bool) : Bool := firstTyped && decide (1 ≤ firstChars) && secondTyped && decide (1 ≤ secondChars) && (!escapeLike || knownRoot || hasThirdSeparator)
theorem accepted_root_has_two_typed_components (firstChars secondChars : Nat) (firstTyped secondTyped knownRoot escapeLike hasThirdSeparator : Bool) (accepted : acceptsSingleBackslashRoot firstChars secondChars firstTyped secondTyped knownRoot escapeLike hasThirdSeparator = true) :
    firstTyped = true ∧ 1 ≤ firstChars ∧ secondTyped = true ∧ 1 ≤ secondChars ∧ (escapeLike = false ∨ knownRoot = true ∨ hasThirdSeparator = true) := by simpa [acceptsSingleBackslashRoot, and_assoc, or_assoc] using accepted
theorem escape_without_known_root_is_rejected (firstChars secondChars : Nat) (firstTyped secondTyped : Bool) : acceptsSingleBackslashRoot firstChars secondChars firstTyped secondTyped false true false = false := by simp [acceptsSingleBackslashRoot]
theorem empty_component_is_rejected (firstChars secondChars : Nat) (firstTyped secondTyped knownRoot escapeLike hasThirdSeparator : Bool) (empty : firstChars = 0 ∨ secondChars = 0) : acceptsSingleBackslashRoot firstChars secondChars firstTyped secondTyped knownRoot escapeLike hasThirdSeparator = false := by rcases empty with rfl | rfl <;> simp [acceptsSingleBackslashRoot]
def continuesAcrossSpace (typedTail hasSeparator : Bool) : Bool := typedTail && hasSeparator
theorem continued_space_has_typed_separator (typedTail hasSeparator : Bool) (continued : continuesAcrossSpace typedTail hasSeparator = true) : typedTail = true ∧ hasSeparator = true := by simpa [continuesAcrossSpace] using continued
theorem prose_without_separator_stops (typedTail : Bool) : continuesAcrossSpace typedTail false = false := by simp [continuesAcrossSpace]
